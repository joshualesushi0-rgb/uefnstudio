<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>UEFN Studio</title>

<style>

body{
background:#0f0f0f;
color:white;
font-family:Arial;
margin:0;
}

header{
background:#151515;
padding:30px;
text-align:center;
}

h1{
margin:0;
font-size:40px;
}

.container{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:30px;
padding:40px;
}

.card{
background:#1c1c1c;
border-radius:10px;
width:260px;
padding:20px;
text-align:center;
}

.card img{
width:100%;
border-radius:6px;
}

.price{
font-size:22px;
color:#ff7b00;
margin:10px 0;
}

button{
background:#ff7b00;
border:none;
padding:10px 20px;
color:white;
border-radius:6px;
cursor:pointer;
}

</style>

</head>

<body>

<header>
<h1>UEFN STUDIO</h1>
<p>UEFN Maps & Assets</p>
</header>

<div class="container">

<div class="card">
<img src="map1.png">
<h3>Weapon Wall Pack</h3>
<p>UEFN asset pack</p>
<div class="price">10$</div>
<button>Download</button>
</div>

<div class="card">
<img src="map2.png">
<h3>Verse Script Pack</h3>
<p>Useful Verse scripts</p>
<div class="price">5$</div>
<button>Download</button>
</div>

<div class="card">
<img src="map3.png">
<h3>Fortnite Map Template</h3>
<p>Starter template</p>
<div class="price">Free</div>
<button>Download</button>
</div>

</div>

</body>
</html>
